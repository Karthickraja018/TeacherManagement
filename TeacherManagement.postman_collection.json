{
	"info": {
		"name": "TeacherManagement API",
		"description": "Complete API collection for Teacher Management System with Role-Based Authorization (Admin / Teacher / Student).\n\n**Quick Start:**\n1. Run *Login as Admin*, *Login as Teacher*, or *Login as Student* — tokens are saved automatically to environment variables.\n2. Every protected request uses `{{token}}` (the last login). Role-specific folders carry the matching token variable.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints — Register, Login, Refresh and Revoke tokens.\nLogin responses auto-save the JWT and refresh token to environment variables.",
			"item": [
				{
					"name": "Register as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    pm.environment.set('adminToken', body.token);",
									"    pm.environment.set('adminRefreshToken', body.refreshToken);",
									"    pm.environment.set('token', body.token);",
									"    pm.environment.set('refreshToken', body.refreshToken);",
									"    console.log('Admin registered. Token saved.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin_user\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"Admin\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/Auth/Register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "Auth", "Register"]
						}
					},
					"response": []
				},
